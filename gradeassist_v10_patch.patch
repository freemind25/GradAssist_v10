+export interface EvaluationData {
+  id: string; // Unique ID for this evaluation instance
+  studentNames: string[];
+  projectName: string;
+  studyLevel: string;
+  studySubLevel: string;
+  session: string;
+  academicYear: string;
+  universityName: string;
