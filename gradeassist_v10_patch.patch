+name: CI — GradeAssist
+
+on:
+  push:
+    branches: [main, develop]
+  pull_request:
+    branches: [main]
+
+concurrency:
+  group: ${{ github.workflow }}-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  # ─── Qualité du code ──────────────────────────────────────────────────────────
+  quality:
+    name: Lint + TypeCheck + Build
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Setup Node.js 20
+        uses: actions/setup-node@v4
+        with:
+          node-version: '20'
+          cache: 'npm'
+
+      - name: Install dependencies
+        run: npm ci
+
+      - name: TypeScript — vérification types
+        run: npx tsc --noEmit
+
+      - name: ESLint — vérification qualité
+        run: npm run lint
+
+      - name: Next.js — build de production
+        run: npm run build
+        env:
+          # Désactiver la télémétrie Next.js en CI
+          NEXT_TELEMETRY_DISABLED: 1
+          # Clé IA optionnelle (non requise pour le build)
+          GOOGLE_GENAI_API_KEY: ${{ secrets.GOOGLE_GENAI_API_KEY }}
+
+      - name: Upload build artifacts
+        uses: actions/upload-artifact@v4
+        if: success()
+        with:
+          name: nextjs-build
+          path: .next/
+          retention-days: 1
+
+  # ─── Tests E2E Cypress ────────────────────────────────────────────────────────
+  e2e:
+    name: Cypress E2E Tests
+    runs-on: ubuntu-latest
+    timeout-minutes: 20
+    needs: quality
+
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Setup Node.js 20
+        uses: actions/setup-node@v4
+        with:
+          node-version: '20'
+          cache: 'npm'
+
+      - name: Install dependencies
+        run: npm ci
+
+      - name: Install Cypress binary
+        run: npx cypress install
+
+      - name: Download build artifacts
+        uses: actions/download-artifact@v4
+        with:
+          name: nextjs-build
+          path: .next/
+
+      - name: Cypress — Run E2E Tests
+        uses: cypress-io/github-action@v6
+        with:
+          # Démarrer l'app Next.js en mode production
+          start: npm run start
+          wait-on: 'http://localhost:3000'
+          wait-on-timeout: 60
+          browser: chrome
+          headless: true
+          # Lancer les suites dans l'ordre (smoke en premier)
+          spec: |
+            cypress/e2e/00-smoke.cy.ts
+            cypress/e2e/01-chargement.cy.ts
+            cypress/e2e/02-gestion-modules.cy.ts
+            cypress/e2e/03-informations-evaluation.cy.ts
+            cypress/e2e/04-grille-evaluation.cy.ts
+            cypress/e2e/05-presences.cy.ts
+            cypress/e2e/06-exports.cy.ts
+            cypress/e2e/07-accessibilite-responsive.cy.ts
+        env:
+          NEXT_TELEMETRY_DISABLED: 1
+          CYPRESS_BASE_URL: http://localhost:3000
+
+      - name: Upload screenshots (si échec)
+        uses: actions/upload-artifact@v4
+        if: failure()
+        with:
+          name: cypress-screenshots
+          path: cypress/screenshots/
+          retention-days: 7
+
+      - name: Upload videos (si échec)
+        uses: actions/upload-artifact@v4
+        if: failure()
+        with:
+          name: cypress-videos
+          path: cypress/videos/
+          retention-days: 7
